graph TD
    %% Define External Actors
    SVMS["📷 SVMS / API Source<br/>(Camera, VMS, Scanner)"]
    FE["💻 Frontend Dashboard<br/>(React / Electron)"]
    CMS_BE["☁️ CMS Backend<br/>(Primary Storage)"]
    Peer_BE["↔️ Peer Middle BE<br/>(Neighbor Node)"]

    subgraph Middle_Backend ["Middle Backend Architecture"]
        direction TB

        %% Entry point
        App["📦 app.js<br/>(Express + Middleware)"]

        subgraph Routes ["API Endpoints (Routes)"]
            LR["📝 logs.routes.js<br/>/api/v1/logs"]
            SR["🖥️ server.routes.js<br/>/api/v1/server<br/>/api/v1/devices"]
            CR["🔗 connections.routes.js<br/>/api/v1/create-connection"]
            AR["🔑 auth.routes.js<br/>/api/v1/login"]
        end

        subgraph State ["Shared State (socketState.js)"]
            ServersMap["Map: Servers Info"]
            DevicesMap["Map: Devices List"]
            ConnectionsList["Array: Peer Connections"]
            SocketIO["Socket.IO Instance"]
        end

        subgraph Logic ["Core Logic Units"]
            Forwarder["Forwarding Utility<br/>(with Retry & Auth)"]
            Syncer["Data Sync Engine<br/>(Initial Sync)"]
            Notify["Notification Helper<br/>(Health Status)"]
        end
    end

    %% DATA FLOW: INCOMING
    SVMS -- "POST Logs" --> LR
    SVMS -- "POST Server/Devices" --> SR
    Peer_BE -- "Sync Data (POST)" --> SR
    FE -- "Config / Control" --> CR

    %% PROCESSING & STATE UPDATES
    LR --> SocketIO
    SR --> ServersMap
    SR --> DevicesMap
    CR --> ConnectionsList
    CR -- "Trigger Initial Sync" --> Syncer

    %% STATE -> LOGIC
    ServersMap & DevicesMap --> Syncer
    ConnectionsList --> Forwarder
    ConnectionsList --> Notify

    %% DATA FLOW: OUTGOING
    SocketIO -- "emit('receive-log')" --> FE
    SocketIO -- "emit('receive-server-info')" --> FE
    
    Forwarder -- "HTTP POST (Logs/Server)" --> CMS_BE
    Forwarder -- "HTTP POST (Synced Data)" --> Peer_BE
    
    Syncer -- "HTTP POST (Bulk Data)" --> Peer_BE
    
    Notify -- "socket.emit('status-update')" --> FE

    %% Styling
    style Middle_Backend fill:#f0f4f8,stroke:#2c3e50,stroke-width:2px
    style SVMS fill:#e1f5fe,stroke:#01579b
    style FE fill:#e8f5e9,stroke:#2e7d32
    style CMS_BE fill:#fff3e0,stroke:#e65100
    style Peer_BE fill:#f3e5f5,stroke:#7b1fa2
    style State fill:#ffffff,stroke:#7f8c8d,stroke-dasharray: 5 5
