graph TD
    classDef file fill:#f9f9f9,stroke:#333,stroke-width:2px;
    classDef function fill:#fff,stroke:#007bff,stroke-width:1px;
    classDef route fill:#e7f3ff,stroke:#007bff,stroke-width:2px;

    subgraph "📂 cms-middle-be/src/app.js"
        AppNode["serialize(body: any) -> string | undefined"]
        Middleware["Logger Middleware(req, res, next) -> void"]
    end
    class AppNode,Middleware function;

    subgraph "📂 routes/logs.routes.js"
        LogRoute["POST /api/v1/logs(req.body: LogData) -> {success: bool}"]
        ForwardRetry["forwardWithRetry(conn: object, logData: object) -> Promise<bool>"]
    end
    class LogRoute route;
    class ForwardRetry function;

    subgraph "📂 routes/server.routes.js"
        ServerRoute["POST /api/v1/server(req.body: ServerData) -> {success: bool, count: int}"]
        DeviceRoute["POST /api/v1/devices(req.body: DeviceList) -> {success: bool, count: int}"]
        ForwardTargets["forwardToSendTargets(endpoint: string, data: object) -> Promise<void>"]
        SyncTarget["syncDataToTarget(url: string, token: string) -> Promise<void>"]
    end
    class ServerRoute,DeviceRoute route;
    class ForwardTargets,SyncTarget function;

    subgraph "📂 routes/connections.routes.js"
        CreateConn["POST /api/v1/create-connection(req.body: {ip, port, mode}) -> {success, status}"]
        GetConns["GET /api/v1/connections() -> {sendList, receiveList, activeClients}"]
    end
    class CreateConn,GetConns route;

    subgraph "📂 helpers/notify.js"
        NotifyStatus["notifyStatusToClients(url, mode, status, data) -> void (Emit Socket)"]
        GetActive["getActiveClients() -> Promise<Array<Client>>"]
        RemoveConn["removeConnection(url) -> {success: bool, message: string}"]
    end
    class NotifyStatus,GetActive,RemoveConn function;

    subgraph "📂 socketState.js"
        StateVars["State: servers (Map), devices (Map), connections (Array)"]
    end

    %% Mối liên kết (Calls & Flows)
    LogRoute -- calls --> ForwardRetry
    LogRoute -- updates --> StateVars
    
    ServerRoute -- calls --> ForwardTargets
    ServerRoute -- updates --> StateVars
    
    DeviceRoute -- calls --> ForwardTargets
    DeviceRoute -- updates --> StateVars
    
    CreateConn -- calls --> SyncTarget
    CreateConn -- calls --> NotifyStatus
    
    ForwardRetry -- uses --> NotifyStatus
    ForwardTargets -- uses --> StateVars
    
    SyncTarget -- reads --> StateVars
    
    Middleware -- uses --> AppNode

    %% Chú thích
    direction TB
